# Include your project-specific ignores in this file
# Read about how to use .gitignore: https://help.github.com/articles/ignoring-files
.idea/
.vscode/

# Compiled output
build/**
dist
public/version.json

# Node.js and NPM
node_modules/
/.pnpm-store/
npm-debug.log
proxy.config.js
/flowgen.js
/.nyc_output/
/coverage/
.eslintcache
flow-typed/npm/

# VS Code dev container config
.devcontainer/

#Yarn
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
yarn-error.log
.pnp.*
run.config.default.min.js

# Spec Kit working directories
/.specify/
/specs/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# macOS filesystem metadata
.Spotlight-V100
.Trashes
